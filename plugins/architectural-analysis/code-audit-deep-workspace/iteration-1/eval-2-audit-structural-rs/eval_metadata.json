{
  "eval_id": 2,
  "eval_name": "audit-structural-rs",
  "prompt": "Audit /home/mcs/Documents/git/recast/crates/recast-core/src/structural.rs for me. It's the tree-sitter pipeline for the recast CLI and has grown to 650 lines. I want a deep review focused on function-level complexity and any unbounded recursion risk on parser input. Also call out if there are obvious coupling problems vs the other orchestrator file plan.rs.",
  "assertions": [
    {
      "text": "Covers \u22654 of 7 ground-truth structural.rs findings",
      "type": "coverage",
      "min_hits": 4,
      "findings": [
        {
          "name": "emit_node recursive no depth cap",
          "patterns": [
            "emit_node",
            "depth (cap|bound|limit)",
            "unbounded recursion",
            "stack[- ]overflow",
            "recurs"
          ]
        },
        {
          "name": "field_name_for_child index-vs-id bug",
          "patterns": [
            "field_name_for_child",
            "node id.{0,30}index",
            "id\\(\\).{0,30}(as u32|index)",
            "child index",
            "field.{0,30}(lost|silently|omit)",
            "named_child"
          ]
        },
        {
          "name": "UTF-8 byte walker corruption",
          "patterns": [
            "UTF-?8.{0,30}(corrupt|mangle|drop|lose)",
            "push\\(.{0,15}as char\\)",
            "Latin-?1",
            "multi[- ]?byte",
            "byte.{0,30}codepoint",
            "mangles?.{0,15}(multibyte|UTF)"
          ]
        },
        {
          "name": "dual-orchestrator coupling with plan.rs",
          "patterns": [
            "plan\\.rs",
            "dual orchestrator",
            "re-?implement.{0,30}(scan|collect|finalize)",
            "scan.{0,15}collect.{0,15}finalize",
            "orchestrat",
            "duplication.{0,20}plan",
            "reimplements"
          ]
        },
        {
          "name": "silent literal-to-wildcard fallthrough",
          "patterns": [
            "literal.{0,30}wildcard",
            "if let.{0,40}fallthrough",
            "bare.{0,15}\\(kind\\)",
            "non-?UTF-?8.{0,30}(text|literal)",
            "#eq\\?",
            "literal.{0,30}falls? through",
            "no #eq predicate"
          ]
        },
        {
          "name": "non-deterministic primary-capture pick",
          "patterns": [
            "non-?deterministic",
            "max\\(?capture",
            "iteration order",
            "@root.{0,30}absent",
            "capture[- ]name ordering",
            "fallback.{0,40}primary capture",
            "highest capture index",
            "numerically-highest"
          ]
        },
        {
          "name": "source_file hard-coded root unwrap (non-Rust grammars)",
          "patterns": [
            "source_file",
            "root.{0,20}kind",
            "hard[- ]?cod.{0,30}(root|source_file)",
            "Python.{0,30}module",
            "Bash.{0,30}program",
            "JSON.{0,30}document",
            "(non-?Rust|other) grammar"
          ]
        }
      ]
    },
    {
      "text": "Output contains a 'Top targets' summary section",
      "type": "contains",
      "substring": "Top targets"
    },
    {
      "text": "Each finding includes a fix sketch",
      "type": "regex",
      "pattern": "Fix:",
      "min_matches": 3
    }
  ]
}