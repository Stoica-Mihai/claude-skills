{
  "eval_id": 1,
  "eval_name": "audit-commit-rs",
  "prompt": "Doing a perf + correctness pass on /home/mcs/Documents/git/recast/crates/recast-core/src/commit.rs \u2014 it's the two-phase atomic-commit module for the recast CLI. Anything sketchy in the apply path? I'm especially worried about syscalls happening per-file in a parallel loop, and any error-handling spots where failures might disappear silently (the rollback / recover paths in particular).",
  "assertions": [
    {
      "text": "Covers \u22655 of 8 ground-truth commit.rs findings",
      "type": "coverage",
      "min_hits": 5,
      "findings": [
        {
          "name": "NonceGen clock-per-nonce perf",
          "patterns": [
            "NonceGen",
            "SystemTime",
            "per[- ]nonce",
            "clock.{0,40}nonce"
          ]
        },
        {
          "name": "recover_sweep FS-probe per backup",
          "patterns": [
            "recover_sweep",
            "exists\\(\\)[^.]{0,80}backup",
            "per[- ]backup"
          ]
        },
        {
          "name": "stage_all first-err-wins aggregation",
          "patterns": [
            "stage_all",
            "first[- ]?error",
            "only.{0,15}first.{0,15}err",
            "drops other err"
          ]
        },
        {
          "name": "rollback_committed silent rename failures",
          "patterns": [
            "rollback_committed",
            "rollback.{0,40}(silent|swallow|hide|ignore)",
            "rename.{0,30}(silent|swallow|hide)"
          ]
        },
        {
          "name": "fsync_parents silent on open err",
          "patterns": [
            "fsync_parents",
            "best_effort_fsync",
            "fsync.{0,40}(silent|swallow|ignore|hide)"
          ]
        },
        {
          "name": "delete-backups-before-fsync durability bug",
          "patterns": [
            "(delete|remove|unlink).{0,40}(before|prior to).{0,40}fsync",
            "backup.{0,40}before.{0,40}fsync",
            "durability ordering",
            "ordering.{0,30}(bug|wrong|incorrect)"
          ]
        },
        {
          "name": "--threads not honored in apply phase",
          "patterns": [
            "--threads",
            "thread.?pool.{0,40}(scope|install)",
            "global (rayon )?pool",
            "pool.{0,40}apply_changes",
            "scoped.{0,30}pool",
            "apply.{0,30}global pool"
          ]
        },
        {
          "name": "remove_file-before-rename redundant unlink",
          "patterns": [
            "remove_file.{0,30}rename",
            "unlink.{0,30}rename",
            "redundant.{0,20}(unlink|remove_file)",
            "rename overwrites"
          ]
        }
      ]
    },
    {
      "text": "Output contains a 'Top targets' summary section",
      "type": "contains",
      "substring": "Top targets"
    },
    {
      "text": "Each finding includes a fix sketch (output contains 'Fix:')",
      "type": "regex",
      "pattern": "Fix:",
      "min_matches": 3
    }
  ]
}